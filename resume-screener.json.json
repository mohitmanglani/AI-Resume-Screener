    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.output || $input.first().json.text || '';\n\nif (typeof raw === 'string') {\n  raw = raw.replace(/\\\\n/g, ' ').replace(/\\\\\"/g, '\"').replace(/\\\\\\\\/g, '\\\\');\n}\n\nconst start = raw.indexOf('{');\nconst end = raw.lastIndexOf('}');\n\nif (start === -1 || end === -1) {\n  throw new Error('PARSE_ERROR: No JSON found in LLM response');\n}\n\nraw = raw.substring(start, end + 1);\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  throw new Error(`PARSE_ERROR: ${e.message}`);\n}\n\nreturn [{ json: parsed }];"
      },
