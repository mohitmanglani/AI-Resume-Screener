    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.output || $input.first().json.text || '';\n\nif (typeof raw === 'string') {\n  raw = raw.replace(/\\\\n/g, ' ').replace(/\\\\\"/g, '\"').replace(/\\\\\\\\/g, '\\\\');\n}\n\nconst start = raw.indexOf('{');\nconst end = raw.lastIndexOf('}');\n\nif (start === -1 || end === -1) {\n  throw new Error('PARSE_ERROR: No JSON found in HR Scorer response');\n}\n\nraw = raw.substring(start, end + 1);\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  throw new Error(`PARSE_ERROR: ${e.message}`);\n}\n\nconst candidateData = $('Code in JavaScript').first().json;\n\nreturn [{ json: {\n  ...parsed,\n  candidate_name: candidateData.candidate_name,\n  email: candidateData.email,\n  phone: candidateData.phone,\n  location: candidateData.location,\n  years_of_experience: candidateData.years_of_experience,\n  education: candidateData.education,\n  strengths: candidateData.strengths,\n  weaknesses: candidateData.weaknesses,\n  red_flags: candidateData.red_flags,\n  file_name: $('Google Drive Trigger').first().json.name,\n  timestamp: new Date().toISOString()\n}}];"
      },
