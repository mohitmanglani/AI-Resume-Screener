    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a senior HR recruiter. Score this candidate against the job description below.\n\nJOB DESCRIPTION:\n{{ $('Get row(s) in sheet').item.json.Description }}\n\nCANDIDATE PROFILE:\nName:{{ $('Code in JavaScript').item.json.candidate_name }}\nExperience: {{ $('Code in JavaScript').item.json.years_of_experience }} years\nSkills: {{ $('Code in JavaScript').item.json.skills.join(', ') }}\nTools: {{ $('Code in JavaScript').item.json.tools_and_technologies.join(', ') }}\nStrengths: {{ $('Code in JavaScript').item.json.strengths.join(', ') }}\nWeaknesses: {{ $('Code in JavaScript').item.json.weaknesses.join(', ') }}\nAchievements: {{ $('Code in JavaScript').item.json.achievements.join(', ') }}\nRed Flags: {{ $('Code in JavaScript').item.json.red_flags.join(', ') }}i\n\nReturn ONLY this JSON, no other text:\n{\n  \"score\": 0,\n  \"recommendation\": \"SHORTLIST\" | \"MAYBE\" | \"REJECT\",\n  \"skills_matched\": [],\n  \"skills_missing\": [],\n  \"summary\": \"\"\n}",
        "batching": {}
