      "parameters": {
        "promptType": "define",
        "text": "=You are an expert HR analyst. Extract and analyse the following resume carefully.\n\nResume:\n{{ $('Extract from File').item.json.text }}\n\nReturn ONLY this JSON, no other text:\n{\n  \"candidate_name\": \"\",\n  \"email\": \"\",\n  \"phone\": \"\",\n  \"location\": \"\",\n  \"years_of_experience\": 0,\n  \"education\": \"\",\n  \"skills\": [],\n  \"tools_and_technologies\": [],\n  \"strengths\": [],\n  \"weaknesses\": [],\n  \"achievements\": [],\n  \"red_flags\": []\n}",
